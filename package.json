{
  "name": "shopify-margin-sentinel",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:prod": "prisma generate --schema prisma/postgres/schema.prisma && react-router build",
    "dev": "shopify app dev",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:prod": "prisma generate --schema prisma/postgres/schema.prisma && prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "start": "react-router-serve ./build/server/index.js",
    "start:prod": "prisma migrate deploy --schema prisma/postgres/schema.prisma && react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test:margin": "node scripts/test-margin.mjs",
    "test:margin-helpers": "tsx scripts/test-margin-helpers.ts",
    "test:csv": "node scripts/test-csv.mjs",
    "test:csv-parser": "tsx scripts/test-csv-parser.ts",
    "test:webhook-compliance": "tsx scripts/test-webhook-compliance.ts",
    "test:prod-schema": "DATABASE_URL=postgresql://user:pass@localhost:5432/profit_guard prisma validate --schema prisma/postgres/schema.prisma",
    "test:shopify-products": "tsx scripts/test-shopify-products.ts",
    "shopify": "shopify",
    "prisma": "prisma",
    "test": "npm run test:margin && npm run test:margin-helpers && npm run test:csv && npm run test:csv-parser && npm run test:webhook-compliance && npm run test:prod-schema && npm run test:shopify-products && tsx scripts/test-email.ts && node scripts/test-demo-costs.mjs && node scripts/test-export.mjs && node scripts/test-security.mjs",
    "db:push": "prisma db push",
    "predev": "npx prisma generate"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "isbot": "^5.1.31",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^2.0.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "tsx": "4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  }
}
