NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
SHOPIFY_APP_URL=https://your-hosted-app.example.com
SCOPES=read_products,read_inventory
# Use true only while testing charges on a development store. Use false for paid public launch.
SHOPIFY_BILLING_TEST=false

SUPPORT_EMAIL=support@example.com
BETA_SIGNUP_URL=https://your-form.example.com

# Optional, only needed when weekly alert emails are enabled.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=
